# IDSF Japan — Netlify 環境変数テンプレート
# このファイルは Git にコミットして OK（実際の値は入れない）
# 実際の値は Netlify Dashboard に直接登録する
#   → Site settings > Environment variables > Add variable

# Notion Integration Token
# https://www.notion.so/my-integrations で取得
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion 大会管理データベースの ID（固定値）
# データベース: IDSF Japan 大会管理
# URL: https://www.notion.so/7478a4a53e4b42c18359fe336f9546ee
NOTION_DATABASE_ID=7478a4a53e4b42c18359fe336f9546ee
